{
  "name": "jetpack",
  "version": "5.0.0-rc.4",
  "type": "module",
  "description": "Run and build web code with Rspack.",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./rspack": {
      "types": "./rspack.d.ts",
      "import": "./rspack.js",
      "default": "./rspack.js"
    },
    "./rspack-config": {
      "types": "./rspack-config.d.ts",
      "import": "./rspack-config.js",
      "default": "./rspack-config.js"
    },
    "./html": {
      "types": "./html.d.ts",
      "import": "./html.js",
      "default": "./html.js"
    },
    "./serve": {
      "types": "./serve.d.ts",
      "import": "./serve.js",
      "default": "./serve.js"
    }
  },
  "types": "./index.d.ts",
  "license": "MIT",
  "author": "Karolis Narkevicius",
  "repository": {
    "type": "git",
    "url": "git://github.com/KidkArolis/jetpack.git"
  },
  "keywords": [
    "rspack",
    "jetpack",
    "build"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bin": {
    "jetpack": "./bin/jetpack"
  },
  "files": [
    "bin",
    "lib",
    "docs",
    "*.d.ts",
    "index.js",
    "html.js",
    "rspack-config.js",
    "rspack.js",
    "serve.js"
  ],
  "scripts": {
    "test": "ava && npm run test:types && oxlint && oxfmt --check '**/*.{js,json,css,yml,ts}'",
    "test:types": "tsc -p tsconfig.types.json",
    "coverage": "c8 --reporter=text --reporter=html --include='lib/**/*.js' --include='*.js' --exclude='test/**' --exclude='examples/**' --exclude='lib/retryChunkLoadPlugin.js' ava",
    "format": "oxfmt --write '**/*.{js,json,css,yml}'",
    "release": "npx np",
    "release-rc": "npx np --tag=next --any-branch --no-cleanup"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@rspack/core": "^2.1.4",
    "@rspack/dev-server": "^2.1.0",
    "@rspack/plugin-react-refresh": "^2.0.2",
    "@swc/helpers": "^0.5.23",
    "browserslist": "^4.28.6",
    "browserslist-useragent-regexp": "^4.1.4",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "d3-hierarchy": "^3.1.2",
    "express": "^5.2.1",
    "picocolors": "^1.1.1",
    "react-refresh": "^0.18.0",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "send": "^1.2.1",
    "style-loader": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ava": "^8.0.1",
    "c8": "^12.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "1m"
  }
}
