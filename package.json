{
  "name": "jetpack",
  "version": "4.4.2",
  "type": "module",
  "description": "Jetpack wraps webpack and nodemon to give you the best development workflow.",
  "exports": {
    ".": "./index.js",
    "./rspack": "./rspack.js",
    "./rspack-config": "./rspack-config.js",
    "./html": "./html.js",
    "./serve": "./serve.js"
  },
  "license": "MIT",
  "author": "Karolis Narkevicius",
  "repository": {
    "type": "git",
    "url": "git://github.com/KidkArolis/jetpack.git"
  },
  "keywords": [
    "webpack",
    "jetpack",
    "build"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "jetpack": "./bin/jetpack"
  },
  "files": [
    "bin",
    "lib",
    "docs",
    "index.js",
    "html.js",
    "rspack-config.js",
    "rspack.js",
    "serve.js"
  ],
  "scripts": {
    "test": "ava && oxlint && oxfmt --check '**/*.{js,json,css,yml}'",
    "coverage": "c8 --reporter=text --reporter=html --include='lib/**/*.js' --include='*.js' --exclude='test/**' --exclude='examples/**' --exclude='lib/hmrFirefoxFix.js' --exclude='lib/retryChunkLoadPlugin.js' ava",
    "format": "oxfmt --write '**/*.{js,json,css,yml}'",
    "release": "np",
    "release-alpha": "np --tag=alpha --any-branch --no-cleanup"
  },
  "dependencies": {
    "@rspack/core": "^2.0.3",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "@swc/helpers": "^0.5.21",
    "browserslist": "^4.28.2",
    "browserslist-useragent-regexp": "^4.1.4",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "d3-hierarchy": "^3.1.2",
    "express": "^5.2.1",
    "picocolors": "^1.1.1",
    "react-refresh": "^0.18.0",
    "sass-embedded": "^1.99.0",
    "sass-loader": "^17.0.0",
    "send": "^1.2.1",
    "style-loader": "^4.0.0",
    "webpack-dev-middleware": "^8.0.3",
    "webpack-hot-middleware": "^2.26.1"
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "string-replace-loader": "^3.3.0"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "1m"
  }
}
